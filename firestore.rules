rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── AI Config ──
    // Anyone logged in can read (to show active AI in UI if needed)
    // Only admin can write
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── News Cache ──
    // Public read (news is public info)
    // Only server (Admin SDK) can write — client write blocked
    match /news/{doc} {
      allow read: if true;
      allow write: if false; // Server uses Admin SDK (bypasses rules)
    }

    // ── Study Materials ──
    // Any logged-in user can read (to get study notes)
    // Only admin can write (upload materials)
    match /materials/{matId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── User Profiles ──
    // Each user can only read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // â”€â”€ Analytics â”€â”€
    // Users can listen to their own aggregate analytics.
    // Writes stay server-only through the Admin SDK.
    match /analytics/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /subjects/{subjectId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;

        match /topics/{topicId} {
          allow read: if request.auth != null && request.auth.uid == uid;
          allow write: if false;
        }
      }
    }
  }
}
