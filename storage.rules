rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Study Material PDFs ──
    // Logged-in users can read (download PDFs for reference)
    // Writes blocked from client — only Admin SDK on server can upload
    match /materials/{fileName} {
      allow read: if request.auth != null;
      allow write: if false; // Server uses Admin SDK (bypasses rules)
    }

    // ── User Profile Avatars ──
    // Publicly readable so other users can see them
    // Writes blocked from client — only Admin SDK on server can upload
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if false; // Server uses Admin SDK (bypasses rules)
    }
  }
}
